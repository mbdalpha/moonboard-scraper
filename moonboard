#!/usr/bin/env python3
"""moonboard — one front door for the whole MoonBoard-dataset pipeline.

Instead of running each script by hand, drive the lot from here:

  ./moonboard fetch      capture a phone request, download the catalog, convert
                         (starts the proxy first if it isn't already up)
  ./moonboard proxy      just start the intercepting proxy + print the phone QR
  ./moonboard convert    re-run only the moonlink conversion on existing data
  ./moonboard holds      pull hold photos/layouts from moonboard.com (separate
                         website login) and bundle them for the PWA
  ./moonboard boards     list the boards/angles you can scrape
  ./moonboard select     choose which board + angle to scrape (writes config.json)
  ./moonboard stop       stop the proxy
  ./moonboard config     print the active config.json
  ./moonboard status     show proxy / data / pwa-link state at a glance

Everyday refresh is a single command: ./moonboard fetch  (then, on the phone,
toggle the WireGuard tunnel ON and reload the board's problem list when asked).

Each underlying script still runs standalone — start_proxy.sh, fetch_problems.py,
to_moonlink.py, fetch_hold_layouts.py — this is only a friendlier wrapper around
them, so nothing here locks you into using the CLI.
"""
import argparse
import json
import re
import shutil
import subprocess
import sys
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
DATA = HERE / "data"
CAPTURED = DATA / "captured_requests.jsonl"
CONFIG_FILE = HERE / "config.json"


def _run(cmd, **kw):
    return subprocess.run(cmd, cwd=HERE, **kw)


def proxy_running():
    """True if mitmproxy's WireGuard listener is up (UDP 51820)."""
    try:
        out = subprocess.run(["ss", "-ulnp"], capture_output=True, text=True)
        return ":51820" in out.stdout
    except FileNotFoundError:
        return False


def _count_lines(path):
    try:
        with open(path) as f:
            return sum(1 for line in f if line.strip())
    except FileNotFoundError:
        return 0


def wait_for_capture(timeout=600):
    before = _count_lines(CAPTURED)
    print("On the phone now: WireGuard tunnel ON, then reload the board's "
          "problem list in the Moon app (log out/in if nothing happens).")
    print(f"Waiting up to {timeout // 60} min for a fresh request…")
    for _ in range(timeout):
        if _count_lines(CAPTURED) > before:
            return True
        time.sleep(1)
    return False


def cmd_proxy(args):
    if proxy_running():
        print("Proxy already listening on UDP 51820.")
        return
    _run(["bash", "start_proxy.sh"])


def cmd_stop(args):
    _run(["pkill", "-f", "mitmdump"])
    print("Proxy stopped (if it was running). On the phone, toggle the "
          "WireGuard tunnel OFF when you're done.")


def cmd_config(args):
    from config import load_config
    print(json.dumps(load_config(), indent=2, ensure_ascii=False))


def _norm_angle(a):
    """'40' / '40°' / 'all' -> '40°' / 'all'. Returns None if unrecognised."""
    a = str(a).strip().lower()
    if a in ("all", ""):
        return "all"
    m = re.match(r"^(\d+)\s*(°|deg(rees?)?)?$", a)
    return m.group(1) + "°" if m else None


def _read_config_raw():
    if CONFIG_FILE.exists():
        try:
            return json.loads(CONFIG_FILE.read_text())
        except json.JSONDecodeError as e:
            sys.exit(f"config.json is not valid JSON: {e}")
    return {}


def _selected_ids(raw):
    return {b.get("id") for b in raw.get("boards", []) if isinstance(b, dict)}


def cmd_boards(args):
    from config import KNOWN_BOARDS
    selected = _selected_ids(_read_config_raw())
    print("Boards you can scrape (id · name · angles):\n")
    for b in KNOWN_BOARDS:
        mark = "●" if b["id"] in selected else " "
        print(f"  {mark} {b['id']:>3}  {b['name']:<22} {', '.join(b['angles'])}")
    print("\n● = in the current config.  "
          "Change it with: ./moonboard select")


def _board_entry(known, angle):
    return {"id": known["id"], "name": known["name"],
            "angles": "all" if angle == "all" else [angle]}


def _ask(prompt, choices):
    """Prompt for a 1-based choice; returns the chosen item."""
    for i, (label, _) in enumerate(choices, 1):
        print(f"  {i}) {label}")
    while True:
        raw = input(prompt).strip()
        if raw.isdigit() and 1 <= int(raw) <= len(choices):
            return choices[int(raw) - 1][1]
        print(f"  enter a number 1–{len(choices)}")


def _select_interactive():
    from config import KNOWN_BOARDS
    if not sys.stdin.isatty():
        sys.exit("Not a terminal — pass --board and --angle "
                 "(e.g. ./moonboard select --board 21 --angle 40, "
                 "or --all).")
    print("Which board?")
    choices = [(f"{b['name']} ({', '.join(b['angles'])})", b)
               for b in KNOWN_BOARDS]
    choices.append(("all boards", "all"))
    pick = _ask("Choose [1–%d]: " % len(choices), choices)

    boards = KNOWN_BOARDS if pick == "all" else [pick]
    # offer the angles available across the chosen board(s)
    avail = sorted({a for b in boards for a in b["angles"]},
                   key=lambda a: int(a.rstrip("°")))
    if len(avail) == 1:
        angle = avail[0]
    else:
        print("\nWhich angle?")
        ac = [(a, a) for a in avail] + [("all angles", "all")]
        angle = _ask("Choose [1–%d]: " % len(ac), ac)
    return boards, angle


def _resolve_board(ref):
    """Match --board against id, exact name, or unambiguous name substring."""
    from config import KNOWN_BOARDS, known_board
    b = known_board(ref)
    if b:
        return [b]
    r = str(ref).strip().lower()
    return [x for x in KNOWN_BOARDS if r in x["name"].lower()]


def cmd_select(args):
    from config import KNOWN_BOARDS

    valid_angles = sorted({a for b in KNOWN_BOARDS for a in b["angles"]},
                          key=lambda a: int(a.rstrip("°")))

    if args.all or args.board or args.angle:
        # non-interactive
        if args.all:
            boards = KNOWN_BOARDS
        elif args.board:
            boards = _resolve_board(args.board)
            if not boards:
                opts = ", ".join(f"{x['id']} ({x['name']})" for x in KNOWN_BOARDS)
                sys.exit(f"unknown board {args.board!r} — pick one of: {opts}")
            if len(boards) > 1:
                names = ", ".join(f"{x['id']} ({x['name']})" for x in boards)
                sys.exit(f"{args.board!r} matches several boards: {names} — "
                         "use the id")
        else:
            sys.exit("give a board: --board <id|name> or --all")
        angle = _norm_angle(args.angle) if args.angle else "all"
        if angle is None:
            sys.exit(f"bad --angle {args.angle!r} — use {', '.join(valid_angles)}, or all")
        if angle != "all" and angle not in valid_angles:
            sys.exit(f"no board has {angle} problems — available: "
                     f"{', '.join(valid_angles)}, or all")
    else:
        boards, angle = _select_interactive()

    entries = [_board_entry(b, angle) for b in boards]

    # warn if a chosen board doesn't have the requested angle
    if angle != "all":
        for b in boards:
            if angle not in b["angles"]:
                print(f"note: {b['name']} has no {angle} problems — "
                      "it'll come out empty.")

    raw = _read_config_raw()
    raw["boards"] = entries
    CONFIG_FILE.write_text(json.dumps(raw, indent=2, ensure_ascii=False) + "\n")

    desc = ", ".join(f"{e['name']} "
                     f"({'all angles' if e['angles'] == 'all' else e['angles'][0]})"
                     for e in entries)
    print(f"\nconfig.json set to: {desc}")
    print("Run ./moonboard fetch to scrape it.")


def cmd_status(args):
    from config import load_config
    cfg = load_config()
    print(f"proxy:    {'running (UDP 51820)' if proxy_running() else 'stopped'}")
    print(f"captured: {_count_lines(CAPTURED)} requests logged")
    auth = DATA / "auth_headers.json"
    print(f"auth:     {'present' if auth.exists() else 'none'} "
          f"({auth.name})")
    print("datasets:")
    found = sorted(DATA.glob("*_all.json")) if DATA.exists() else []
    for p in found:
        mb = p.stat().st_size / 1e6
        print(f"  {p.name}  ({mb:.1f} MB)")
    if not found:
        print("  none yet — run ./moonboard fetch")
    pwa = cfg.get("moonlink_pwa_dir")
    print(f"pwa link: {pwa or 'not configured'}")


def cmd_fetch(args):
    import urllib.error
    import fetch_problems
    import to_moonlink

    if not proxy_running():
        print("Proxy isn't running — starting it (scan the QR below the "
              "first time)…\n")
        cmd_proxy(args)
        print()
        # give mitmproxy a moment to settle before we start watching
        time.sleep(2)

    if not wait_for_capture(timeout=args.timeout):
        sys.exit("No fresh request seen — is the WireGuard tunnel ON and the "
                 "app reloading? (Re-run ./moonboard fetch to try again.)")

    print("\nFresh request captured. Extracting headers + downloading…")
    if not fetch_problems.extract_auth_headers():
        sys.exit("Captured traffic but found no authenticated ems-x request — "
                 "reload the problem list in the app (log out/in if needed).")
    try:
        fetch_problems.main()
    except urllib.error.HTTPError as e:
        sys.exit(f"HTTP {e.code} — tokens likely expired; just run "
                 f"./moonboard fetch again. {e.read()[:200]}")

    if not args.no_convert:
        print()
        to_moonlink.main()


def cmd_convert(args):
    import to_moonlink
    to_moonlink.main()


def cmd_holds(args):
    # holds come from moonboard.com (not the phone/app path), so it needs a
    # website login: env vars or credentials.json next to this script.
    import os
    has_env = os.environ.get("MOONBOARD_USERNAME") and os.environ.get("MOONBOARD_PASSWORD")
    if not (has_env or (HERE / "credentials.json").exists()):
        sys.exit("holds needs a moonboard.com login — set MOONBOARD_USERNAME / "
                 "MOONBOARD_PASSWORD, or copy credentials.example.json to "
                 "credentials.json and fill it in.")
    if shutil.which("nix-shell"):
        cmd = ["nix-shell", "-p", "python3.withPackages (p: [p.playwright])",
               "--run", "python3 fetch_hold_layouts.py"]
    else:
        cmd = ["python3", "fetch_hold_layouts.py"]
    sys.exit(_run(cmd).returncode)


def main():
    p = argparse.ArgumentParser(
        prog="moonboard",
        description="One CLI for the MoonBoard-dataset pipeline.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="Everyday refresh:  ./moonboard fetch")
    sub = p.add_subparsers(dest="command")

    pf = sub.add_parser("fetch", help="capture + download + convert (the usual run)")
    pf.add_argument("--timeout", type=int, default=600,
                    metavar="SECS", help="how long to wait for a phone request")
    pf.add_argument("--no-convert", action="store_true",
                    help="download only; skip the moonlink conversion")
    pf.set_defaults(func=cmd_fetch)

    sub.add_parser("proxy", help="start the intercepting proxy + print the QR"
                   ).set_defaults(func=cmd_proxy)
    sub.add_parser("convert", help="re-run the moonlink conversion only"
                   ).set_defaults(func=cmd_convert)
    sub.add_parser("holds",
                   help="pull hold photos from moonboard.com "
                        "(headed Chrome + website login)"
                   ).set_defaults(func=cmd_holds)

    sub.add_parser("boards", help="list the boards/angles you can scrape"
                   ).set_defaults(func=cmd_boards)
    ps = sub.add_parser("select",
                        help="choose board + angle to scrape (writes config.json)")
    ps.add_argument("--board", metavar="ID|NAME",
                    help="board id or name (e.g. 21 or '2024')")
    ps.add_argument("--angle", metavar="DEG", help="40, 25, or all")
    ps.add_argument("--all", action="store_true",
                    help="scrape every known board (all angles)")
    ps.set_defaults(func=cmd_select)

    sub.add_parser("stop", help="stop the proxy").set_defaults(func=cmd_stop)
    sub.add_parser("config", help="print the active config.json"
                   ).set_defaults(func=cmd_config)
    sub.add_parser("status", help="show proxy/data/link state"
                   ).set_defaults(func=cmd_status)

    args = p.parse_args()
    if not getattr(args, "func", None):
        p.print_help()
        return
    args.func(args)


if __name__ == "__main__":
    main()
